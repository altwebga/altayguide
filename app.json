{
  "expo": {
    "name": "altayguide",
    "slug": "altayguide",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kosmos.altayguide"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kosmos.altayguide"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "d7cc76cf-0492-468d-a632-225932c24ec7"
      }
    },
    "owner": "kos-mos",
    "updates": {
      "url": "https://u.expo.dev/d7cc76cf-0492-468d-a632-225932c24ec7"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
